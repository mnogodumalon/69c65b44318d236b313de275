  { key: 'gegenstand_ref', label: 'Ausrüstungsgegenstand', type: 'applookup/select', targetEntity: 'ausruestungsgegenstand', targetAppId: 'AUSRUESTUNGSGEGENSTAND', displayField: 'bezeichnung' },
